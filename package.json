{
  "name": "phased",
  "version": "0.0.0",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port ${CMUX_PORT:-4200}",
    "build": "ng build",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "ng e2e",
    "storybook": "ng run phased:storybook",
    "build-storybook": "ng run phased:build-storybook",
    "playwright": "npx playwright test",
    "size": "ng build --stats-json",
    "display": "npx esbuild-visualizer --metadata=dist/phased/stats.json --open=true"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "22.0.2",
    "@angular/common": "22.0.4",
    "@angular/compiler": "22.0.4",
    "@angular/core": "22.0.4",
    "@angular/forms": "22.0.4",
    "@angular/material": "22.0.2",
    "@angular/platform-browser": "22.0.4",
    "@angular/platform-browser-dynamic": "22.0.4",
    "@angular/router": "22.0.4",
    "@angular/service-worker": "22.0.4",
    "@babylonjs/core": "9.12.0",
    "@ngrx/signals": "21.1.1",
    "@stdlib/math-base-special-besselj1": "^0.3.1",
    "complex.js": "^2.4.3",
    "echarts": "^6.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "webpack": "5.107.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "22.0.5",
    "@angular-eslint/builder": "21.4.0",
    "@angular-eslint/eslint-plugin": "21.4.0",
    "@angular-eslint/eslint-plugin-template": "21.4.0",
    "@angular-eslint/schematics": "21.4.0",
    "@angular-eslint/template-parser": "21.4.0",
    "@angular/build": "22.0.5",
    "@angular/cli": "22.0.5",
    "@angular/compiler-cli": "22.0.4",
    "@babel/core": "^7.28.5",
    "@chromatic-com/storybook": "^5.1.2",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-links": "^10.4.6",
    "@storybook/angular": "^10.4.6",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "chromatic": "^17.4.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-storybook": "^10.2.14",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.1",
    "storybook": "^10.4.6",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "storybook": "$storybook",
    "webpack": "$webpack"
  }
}
